{
  "name": "automation-exercise",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:api": "playwright test --project=api-tests",
    "test:logged": "playwright test --project=chromium-logged-in",
    "test:guest": "playwright test --project=chromium-guest",
    "test:all:metrics": "playwright test --grep-invert \"@ai-healing|@visual\"; npm run metrics",
    "test:api:metrics": "playwright test --project=api-tests; npm run metrics",
    "test:guest:metrics": "playwright test --project=chromium-guest; npm run metrics",
    "test:logged:metrics": "playwright test --project=chromium-logged-in; npm run metrics",
    "test:visual": "playwright test --project=visual-regression",
    "test:smoke": "playwright test --grep @smoke",
    "test:e2e": "playwright test --grep @e2e",
    "test:flaky": "playwright test --grep @flaky",
    "test:ui": "playwright test --ui",
    "test:report": "playwright show-report",
    "metrics": "npx ts-node scripts/generate-metrics.ts",
    "metrics:api-coverage": "npx ts-node scripts/api-coverage.ts",
    "trends": "npx ts-node scripts/update-trends.ts",
    "trends:chart": "npx ts-node scripts/generate-trends-chart.ts",
 "report:generate": "npx ts-node scripts/write-allure-env.ts && rm -rf allure-report && npx allure generate -o allure-report ./allure-results && npx ts-node scripts/copy-allure-history.ts && npm run trends:chart",
"report:allure": "npm run report:generate && npx allure open allure-report",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit -p tsconfig.json --skipLibCheck",
    "prepare": "husky",
    "test:pre-push": "docker-compose build playwright && docker-compose run --rm --remove-orphans playwright npx playwright test --grep-invert \"@ai-healing|@visual|@api\"",
    "docker:test": "docker-compose run --rm playwright",
    "docker:update": "docker-compose run --rm playwright npx playwright test --update-snapshots"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@commitlint/cli": "^20.3.0",
    "@commitlint/config-conventional": "^20.3.0",
    "@faker-js/faker": "^10.2.0",
    "@playwright/test": "^1.57.0",
    "@types/node": "^25.0.3",
    "@typescript-eslint/eslint-plugin": "^8.52.0",
    "@typescript-eslint/parser": "^8.52.0",
    "allure-commandline": "^2.37.0",
    "allure-playwright": "^3.5.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-check-file": "^3.3.1",
    "eslint-plugin-playwright": "^2.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.7.4"
  },
  "lint-staged": {
    "**/*.ts": [
      "eslint --fix",
      "bash -c 'npm run type-check'"
    ]
  },
  "dependencies": {
    "openai": "^6.18.0"
  }
}
